#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# pre-commit hook — blocks commits that contain:
#   1. Real Twilio / API credentials (SIDs, secrets, live URLs)
#   2. The real .env file with secrets
#   3. Large generated test build artifacts
#
# Install: this file is at .git/hooks/pre-commit  (already installed)
# To bypass in emergency: git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color
ERRORS=0
echo ""
echo "🔍 Running pre-commit security checks..."
# ── 1. Block real credential patterns ────────────────────────────────────────
# Add any new real SIDs/secrets here as you rotate them.
FORBIDDEN_PATTERNS=(
  "TWILIO_API_KEY_SECRET=[A-Za-z0-9]"
  "apiKeySid = 'SK[a-f0-9]"
  "accountSid = 'AC[a-f0-9]"
  "pushCredentialSid = 'CR[a-f0-9]"
  "outgoingApplicationSid = 'AP[a-f0-9]"
  "tokenServerBaseUrl = 'https://[a-z0-9-]*\.onrender\.com'"
  "TWILIO_ACCOUNT_SID=AC[a-f0-9]"
  "TWILIO_API_KEY_SID=SK[a-f0-9]"
  "TWILIO_TWIML_APP_SID=AP[a-f0-9]"
  "TWILIO_PUSH_CREDENTIAL_SID=CR[a-f0-9]"
)
# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
for PATTERN in "${FORBIDDEN_PATTERNS[@]}"; do
  MATCHES=$(git diff --cached -U0 | grep "^+" | grep -v "^+++" | grep -E "$PATTERN" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}❌ BLOCKED: Real credential pattern found:${NC}"
    echo -e "${RED}   Pattern: $PATTERN${NC}"
    echo "$MATCHES" | head -3
    echo ""
    ERRORS=$((ERRORS + 1))
  fi
done
# ── 2. Block twilio_app_config.dart with real values ─────────────────────────
for FILE in $STAGED_FILES; do
  if echo "$FILE" | grep -q "twilio_app_config\.dart$"; then
    # Check it only has placeholder values
    REAL_CREDS=$(git diff --cached "$FILE" | grep "^+" | grep -v "^+++" | \
      grep -E "= '(AC|SK|AP|CR)[a-f0-9]{32}" 2>/dev/null)
    if [ -n "$REAL_CREDS" ]; then
      echo -e "${RED}❌ BLOCKED: twilio_app_config.dart contains real credentials!${NC}"
      echo -e "${RED}   File: $FILE${NC}"
      echo -e "${YELLOW}   Use placeholder values like 'YOUR_ACCOUNT_SID'${NC}"
      echo ""
      ERRORS=$((ERRORS + 1))
    fi
  fi
done
# ── 3. Block .env files with real secrets ────────────────────────────────────
for FILE in $STAGED_FILES; do
  if echo "$FILE" | grep -qE "(^|/)\.env$"; then
    REAL_ENV=$(git diff --cached "$FILE" | grep "^+" | grep -v "^+++" | \
      grep -E "=(AC|SK|AP|CR)[a-zA-Z0-9]{20,}" 2>/dev/null)
    if [ -n "$REAL_ENV" ]; then
      echo -e "${RED}❌ BLOCKED: .env file contains real credentials!${NC}"
      echo -e "${RED}   File: $FILE${NC}"
      echo -e "${YELLOW}   The real .env should be in .gitignore, not committed.${NC}"
      echo ""
      ERRORS=$((ERRORS + 1))
    fi
  fi
done
# ── 4. Warn about large test/build files ─────────────────────────────────────
for FILE in $STAGED_FILES; do
  # Block build/ and .dart_tool/ directories from being staged
  if echo "$FILE" | grep -qE "(^|/)(build|\.dart_tool|Pods|\.gradle)/"; then
    echo -e "${RED}❌ BLOCKED: Build artifact should not be committed:${NC}"
    echo -e "${RED}   $FILE${NC}"
    echo -e "${YELLOW}   Run: git rm --cached \"$FILE\"${NC}"
    ERRORS=$((ERRORS + 1))
  fi
  # Warn about large files over 2MB
  if [ -f "$FILE" ]; then
    SIZE=$(wc -c < "$FILE" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 2097152 ]; then
      SIZE_MB=$(echo "scale=1; $SIZE/1048576" | bc 2>/dev/null || echo "?")
      echo -e "${YELLOW}⚠️  WARNING: Large file staged: $FILE (${SIZE_MB}MB)${NC}"
      echo -e "${YELLOW}   Consider adding to .gitignore if this is a binary/build file.${NC}"
      echo ""
    fi
  fi
done
# ── 5. Warn about firebase_options.dart ──────────────────────────────────────
for FILE in $STAGED_FILES; do
  if echo "$FILE" | grep -q "firebase_options\.dart$"; then
    echo -e "${YELLOW}⚠️  WARNING: firebase_options.dart is staged.${NC}"
    echo -e "${YELLOW}   This file contains Firebase project identifiers.${NC}"
    echo -e "${YELLOW}   It is safe to commit for open-source projects but${NC}"
    echo -e "${YELLOW}   should NOT be committed if your Firebase project is private.${NC}"
    echo ""
  fi
done
# ── Result ────────────────────────────────────────────────────────────────────
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}  Commit BLOCKED — $ERRORS security issue(s) found.${NC}"
  echo -e "${RED}  Fix the issues above, then try again.${NC}"
  echo -e "${RED}  To bypass (NOT recommended): git commit --no-verify${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  exit 1
else
  echo -e "${GREEN}✅ Security checks passed — proceeding with commit.${NC}"
  echo ""
  exit 0
fi