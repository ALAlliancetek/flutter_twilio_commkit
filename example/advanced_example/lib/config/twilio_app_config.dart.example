/// TWILIO APP CONFIGURATION - Advanced Example
///
/// DO NOT commit real credentials to git.
/// This file is listed in .gitignore.
///
/// Setup:
///   1. Copy  lib/config/twilio_app_config.dart.example
///       to   lib/config/twilio_app_config.dart
///   2. Fill in your values from https://console.twilio.com
///
/// See docs/integration_guide.md section 2 for where to find each value.
class TwilioAppConfig {
  TwilioAppConfig._();
  // Twilio Account credentials
  static const String accountSid = 'YOUR_ACCOUNT_SID';       // ACxxxxxxxx
  static const String apiKeySid  = 'YOUR_API_KEY_SID';       // SKxxxxxxxx
  // Voice credentials
  static const String outgoingApplicationSid = 'YOUR_TWIML_APP_SID';       // APxxxxxxxx
  static const String pushCredentialSid      = 'YOUR_PUSH_CREDENTIAL_SID'; // CRxxxxxxxx
  // Token Server
  // Deploy docs/token_server/ to Render.com for a permanent HTTPS URL.
  // See docs/token_server/README.md for step-by-step instructions.
  // For local dev: 'http://10.0.2.2:3000' (Android) or 'http://localhost:3000' (iOS)
  static const String tokenServerBaseUrl = 'https://YOUR_SERVER.onrender.com';
  // Test identities
  static const String userIdentity     = 'flutter-advanced-1';
  static const String defaultVideoRoom = 'advanced-room-001';
  static const String defaultCallTo    = 'flutter-tester-2';
}